 148:Drivers/STM32G4xx_HAL_Driver/Src/stm32g4xx_hal.c **** HAL_StatusTypeDef HAL_Init(void)
 149:Drivers/STM32G4xx_HAL_Driver/Src/stm32g4xx_hal.c **** {
